# Ambiente da aplicação
NODE_ENV=development

# Porta HTTP do servidor
PORT=3000

# PostgreSQL — ajuste conforme seu ambiente local ou Docker
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postsdb

# Chave secreta para assinar tokens JWT (use um valor forte em produção)
JWT_SECRET=change-me-to-a-strong-secret-key

# Chave da API do gemini
GEMINI_API_KEY=GEMINI_API_KEY
